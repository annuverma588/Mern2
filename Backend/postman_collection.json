{
  "info": {
    "name": "Mern2 Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "Register User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set('new_user_email', `postman-${Date.now()}@example.com`);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('registered', () => pm.expect(json.success).to.eql(true));",
              "if (json.token) pm.environment.set('token', json.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"{{new_user_email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users/register",
          "host": ["{{base_url}}"],
          "path": ["api", "users", "register"]
        }
      }
    },
    {
      "name": "Login Seed User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('logged in', () => pm.expect(json.success).to.eql(true));",
              "if (json.token) pm.environment.set('token', json.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users/login",
          "host": ["{{base_url}}"],
          "path": ["api", "users", "login"]
        }
      }
    },
    {
      "name": "Login Seed Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('admin logged in', () => pm.expect(json.success).to.eql(true));",
              "if (json.token) pm.environment.set('admin_token', json.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users/login",
          "host": ["{{base_url}}"],
          "path": ["api", "users", "login"]
        }
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/api/users/profile",
          "host": ["{{base_url}}"],
          "path": ["api", "users", "profile"]
        }
      }
    },
    {
      "name": "Get Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('products loaded', () => pm.expect(json.success).to.eql(true));",
              "if (json.products && json.products[0]) pm.environment.set('product_id', json.products[0]._id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/products?limit=10",
          "host": ["{{base_url}}"],
          "path": ["api", "products"],
          "query": [{ "key": "limit", "value": "10" }]
        }
      }
    },
    {
      "name": "Get Product By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/products/{{product_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "products", "{{product_id}}"]
        }
      }
    },
    {
      "name": "Get Best Seller",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/products/best-seller",
          "host": ["{{base_url}}"],
          "path": ["api", "products", "best-seller"]
        }
      }
    },
    {
      "name": "Get New Arrivals",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/products/new-arrivals",
          "host": ["{{base_url}}"],
          "path": ["api", "products", "new-arrivals"]
        }
      }
    },
    {
      "name": "Get Similar Products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/products/similar/{{product_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "products", "similar", "{{product_id}}"]
        }
      }
    },
    {
      "name": "Create Product Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('product created', () => pm.expect(json.success).to.eql(true));",
              "if (json.product) pm.environment.set('product_id', json.product._id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Classic Cotton Shirt {{$timestamp}}\",\n  \"description\": \"Soft everyday shirt\",\n  \"price\": 1299,\n  \"discountPrice\": 999,\n  \"countInStock\": 25,\n  \"category\": \"Shirts\",\n  \"brand\": \"Rabbit\",\n  \"sizes\": [\"S\", \"M\", \"L\"],\n  \"colors\": [\"White\", \"Blue\"],\n  \"collection\": \"Summer\",\n  \"material\": \"Cotton\",\n  \"gender\": \"unisex\",\n  \"images\": [{ \"url\": \"https://example.com/shirt.jpg\", \"alt\": \"Classic Cotton Shirt\" }],\n  \"isFeatured\": true,\n  \"isPublished\": true,\n  \"tags\": [\"shirt\", \"cotton\"],\n  \"dimensions\": { \"length\": 30, \"width\": 20, \"height\": 2 },\n  \"weight\": 0.4,\n  \"sku\": \"SHIRT-{{$timestamp}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/products",
          "host": ["{{base_url}}"],
          "path": ["api", "products"]
        }
      }
    },
    {
      "name": "Update Product Admin",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"price\": 1199,\n  \"countInStock\": 30,\n  \"isFeatured\": false\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/products/{{product_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "products", "{{product_id}}"]
        }
      }
    },
    {
      "name": "Delete Product Admin",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
        "url": {
          "raw": "{{base_url}}/api/products/{{product_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "products", "{{product_id}}"]
        }
      }
    }
  ]
}
