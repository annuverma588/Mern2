# =============================================
# 🔧 ENVIRONMENT VARIABLES SETUP GUIDE
# =============================================
# यह .env file को डुप्लिकेट करके .env बनाएं
# फिर अपने values के साथ replace करें

# 📡 DATABASE CONNECTION
# MongoDB को connect करने के लिए
# आपका MongoDB URI यहाँ रखें
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/database"

# 🔑 JWT SECRET KEY
# यह एक random, strong string होना चाहिए
# Token को sign करने के लिए use होता है
# Strong key बनाने के लिए: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace_with_a_long_random_secret"

# 🚀 SERVER PORT
# किस port पर server चलेगा
PORT=5000

# 📝 NODE ENVIRONMENT
NODE_ENV=development

# =============================================
# 🎯 कैसे .env file बनाएं:
# =============================================
# 1. इस file को .env के नाम से save करें
# 2. अपने actual values से replace करें
# 3. .gitignore में .env add करें
# 4. कभी भी .env file को GitHub पर push न करें

# =============================================
# 📦 MongoDB Connection String कहाँ से पाएं:
# =============================================
# 1. https://www.mongodb.com/cloud/atlas पर जाएं
# 2. Account बनाएं
# 3. New Cluster बनाएं
# 4. "Connect" button दबाएं
# 5. "Connect Your Application" चुनें
# 6. Connection string copy करें
# 7. <password> को अपने password से replace करें

# =============================================
# 🔐 JWT Secret कैसे generate करें:
# =============================================
# Terminal में यह command run करें:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Output को JWT_SECRET में paste करें
